<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Required for AudioManager.startBluetoothSco() -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Required for any Bluetooth interaction on API < 31 -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <!-- Required for Bluetooth interaction on API 31+ (runtime permission) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!--
        Required for WorkManager to reschedule periodic backup jobs after a
        device reboot. Without this, scheduled backups would silently stop
        firing until the user opens the app again.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Declares microphone usage context for AppOps attribution (API 31+) -->
    <attribution android:tag="microphone" android:label="@string/app_name" />

    <application
        android:name=".SoundTreeApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_n8tree_mark"
        android:label="@string/app_name_extended"
        android:roundIcon="@mipmap/ic_launcher_n8tree_mark"
        android:supportsRtl="true"
        android:theme="@style/Theme.SoundTree">

        <!-- Splash / Entry Activity -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SoundTree.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait" />

        <!-- Recording foreground service (microphone) -->
        <service
            android:name=".service.RecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Playback foreground service (Media3 MediaSessionService) -->
        <!--
            foregroundServiceType="mediaPlayback" is required on API 29+ for
            a service that plays audio while the app is in the background.
            Media3's MediaSessionService handles the foreground notification
            automatically — no startForeground() call needed in our code.

            exported="true" is required so the system media button receiver
            and lock screen controls can bind to this service's MediaSession.
        -->
        <service
            android:name=".service.PlaybackService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!--
            On-connect backup trigger.

            ACTION_MEDIA_MOUNTED is explicitly exempt from the API 26+ restriction
            on implicit broadcast receivers, so static registration here is both
            permitted and necessary — it ensures the backup fires even when the
            app is not running when the user plugs in a designated backup drive.

            Storage broadcasts require a "file" data scheme to be delivered;
            without it the system will not route the intent to this receiver.

            exported="false" — this broadcast is sent by the OS, not by other
            apps, and we have no need to receive it from third parties.
        -->
        <receiver
            android:name=".receiver.StorageMountReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_MOUNTED" />
                <data android:scheme="file" />
            </intent-filter>
        </receiver>

    </application>

</manifest>