<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="30dp">

    <!-- Tappable navigation area — everything left of the X button.
         Gets setOnClickListener in code to navigate to Settings. -->
    <LinearLayout
        android:id="@+id/stripNavArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="44dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvStripStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="?attr/colorTextPrimary"
            android:ellipsize="end"
            android:singleLine="true"
            tools:text="Backing up to SD Card…" />

        <TextView
            android:id="@+id/tvStripBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="?attr/colorTextSecondary"
            android:paddingStart="6dp"
            android:visibility="gone"
            tools:text="+2 more" />

    </LinearLayout>

    <!-- X dismiss button — fixed to trailing edge, sits above nav area in Z order.
         Only shown in Completed state. -->
    <TextView
        android:id="@+id/btnStripDismiss"
        android:layout_width="44dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:gravity="center"
        android:text="✕"
        android:textSize="13sp"
        android:textColor="?attr/colorTextSecondary"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone"
        tools:visibility="visible"
        tools:ignore="HardcodedText" />

    <!-- Progress indicator along bottom edge -->
    <ProgressBar
        android:id="@+id/progressStrip"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:max="10000"
        android:indeterminate="true"
        android:visibility="gone" />

</FrameLayout>