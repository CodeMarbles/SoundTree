<?xml version="1.0" encoding="utf-8"?>
<!--
    view_backup_status_strip.xml
    Title-bar status strip. Third child of titleBarContainer (vertical LinearLayout).
    Slides down on job start, slides back up on dismiss.
    Height is fixed at 30dp so the translate animation offset is constant.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="30dp"
    android:background="?attr/colorSurfaceBase"
    android:clickable="true"
    android:focusable="true">

    <!-- 4dp colored left-edge border (animated alpha when running) -->
    <View
        android:id="@+id/backupStripBorder"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/backup_strip_running" />

    <!-- Status text + "+N more" badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvStripStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="?attr/colorTextPrimary"
            android:ellipsize="end"
            android:singleLine="true"
            tools:text="Backing up to SD Card…" />

        <TextView
            android:id="@+id/tvStripBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="?attr/colorTextSecondary"
            android:paddingStart="6dp"
            android:visibility="gone"
            tools:text="+2 more" />

    </LinearLayout>

    <!-- Thin progress indicator along bottom edge (visible while running) -->
    <ProgressBar
        android:id="@+id/progressStrip"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:max="10000"
        android:indeterminate="true"
        android:visibility="gone" />

</FrameLayout>