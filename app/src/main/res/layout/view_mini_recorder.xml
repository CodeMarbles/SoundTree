<?xml version="1.0" encoding="utf-8"?>
<!--
  Mini Recorder bar v2.

  96dp two-row layout:
    Row 1 (56dp weight): rec/pause | save | [growing timeline]
    Row 2 (40dp weight): elapsed | ← nudge | [MARK pill] | nudge → | ✓ commit

  Changes from v1:
    - MARK button is now a proper filled pill (MaterialButton) matching the
      record tab's mark button style, without the fixed width.
    - Row weights unchanged; timeline vertical centering is handled in code.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="108dp"
    android:background="?attr/colorSurfaceBase"
    android:elevation="4dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Accent line — repositioned by MainActivity for layout order -->
    <View
        android:id="@+id/recAccentLine"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/recContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/recAccentLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Row 0: Recording state label ──────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="18"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/ivMiniRecStateIcon"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_stop_square"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvMiniRecStateLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/record_pill_status_idle"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:singleLine="true" />

            <!-- Topic icon — shown when recording has a topic assigned -->
            <TextView
                android:id="@+id/tvMiniRecTopicIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:paddingEnd="2dp"
                android:visibility="gone" />

            <!-- Minimize button — sends widget to title-bar pill -->
            <ImageView
                android:id="@+id/btnMiniRecorderMinimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_chevron_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mini_recorder_cd_minimize" />

        </LinearLayout>

        <!-- ── Row 1: Rec/Pause + Save + Timeline ────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="50"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- Record / Pause toggle -->
            <ImageView
                android:id="@+id/btnMiniRecPause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_record_circle_mini"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mini_recorder_cd_rec_pause" />

            <!-- Save button -->
            <ImageView
                android:id="@+id/btnMiniRecSave"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_save_check_wave"
                android:padding="3dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mini_recorder_cd_save" />

            <!-- Growing timeline — fills the rest of Row 1 -->
            <app.treecast.ui.widget.MiniRecorderTimelineView
                android:id="@+id/miniRecTimeline"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- ── Row 2: Elapsed + Mark cluster ─────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="38"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <!-- Elapsed time — left aligned -->
            <TextView
                android:id="@+id/tvMiniRecElapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0:00"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- Spacer left -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Topic icon button -->
            <TextView
                android:id="@+id/btnMiniRecTopic"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="@string/topic_emoji_unsorted"
                android:textSize="18sp"
                android:includeFontPadding="false"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mini_recorder_cd_change_topic" />

            <!-- Spacer right -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Delete selected mark — enabled only when a mark is selected -->
            <ImageView
                android:id="@+id/btnMiniRecDeleteMark"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_delete"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="@string/mark_cd_delete" />

            <!-- Nudge last mark back  ← 📍 -->
            <ImageView
                android:id="@+id/btnMiniNudgeBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_mark_nudge_back"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="@string/mark_cd_nudge_back"
                app:tint="?attr/colorMarkSelected" />

            <!--
              MARK button — filled pill matching the record tab's mark button.
              Wrap content width only; no fixed size.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMiniMark"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/mark_btn_add"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="?attr/colorMarkAction"
                app:icon="@drawable/ic_mark"
                app:iconSize="14dp"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:cornerRadius="16dp"
                app:strokeColor="?attr/colorRecordActive"
                app:strokeWidth="2dp"
                android:contentDescription="@string/mark_cd_add" />

            <!-- Nudge last mark forward  📍 → -->
            <ImageView
                android:id="@+id/btnMiniNudgeForward"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_mark_nudge_forward"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="@string/mark_cd_nudge_fwd"
                app:tint="?attr/colorMarkSelected" />

            <!-- Commit / lock nudge -->
            <ImageView
                android:id="@+id/btnMiniNudgeCommit"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_check"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="@string/mark_cd_confirm"
                app:tint="?attr/colorMarkSelected" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>