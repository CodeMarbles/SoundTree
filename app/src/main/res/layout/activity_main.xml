<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:id="@+id/rootStack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Title bar ──────────────────────────────────────── -->
        <!--
            titleBarContainer: outer vertical LinearLayout — unchanged.
            topBar: was a horizontal LinearLayout; converted to FrameLayout
            so that the pill overlay (view_title_pills) can sit on top of
            tvTopTitle via Z-order without affecting the text view's layout.
        -->
        <LinearLayout
            android:id="@+id/titleBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="?attr/colorSurfaceBase">

                <!-- Title text — sits at the back of the Z stack -->
                <TextView
                    android:id="@+id/tvTopTitle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:text="Record"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03" />

                <!-- Pill overlay — draws on top of the title text.
                     Visibility of each pill is controlled by MainActivity. -->
                <include
                    android:id="@+id/titlePills"
                    layout="@layout/view_title_pills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="1px" />

            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorSurfaceElevated" />

        </LinearLayout>

        <!-- ── Page content ───────────────────────────────────────── -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── Mini Player bar (hidden until playback starts) ─────── -->
        <!--
            Sits flush above the bottom nav. Tapping it navigates to
            the Listen tab. Visible only when nowPlaying != null.
        -->
        <include
            android:id="@+id/miniPlayer"
            layout="@layout/view_mini_player"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- ── Mini Recorder bar (hidden until recording starts, or always
        shown when "Always show Mini Recorder" is enabled in Settings) ─ -->
        <include
            android:id="@+id/miniRecorder"
            layout="@layout/view_mini_recorder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />


        <!-- ── Bottom navigation ─────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="?attr/colorSurfaceBase"
            android:elevation="8dp">

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivSettingsIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nav_settings"
                    android:alpha="0.45"
                    app:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvSettingsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textSize="10sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Record -->
            <LinearLayout
                android:id="@+id/navRecord"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivRecordIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nav_record"
                    android:alpha="0.45"
                    app:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvRecordLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Record"
                    android:textSize="10sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Library -->
            <LinearLayout
                android:id="@+id/navLibrary"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivLibraryIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nav_library"
                    android:alpha="0.45"
                    app:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvLibraryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Library"
                    android:textSize="10sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Listen -->
            <LinearLayout
                android:id="@+id/navListen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivListenIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_nav_listen"
                    android:alpha="0.45"
                    app:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvListenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Listen"
                    android:textSize="10sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Lock overlay ───────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🔒  Screen Locked"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnlock"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="100dp"
            android:text="Unlock"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            android:backgroundTint="?attr/colorAccent" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>