<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording row (Inbox / RecordingsAdapter).

  Ripple is on foreground (not background) so the adapter can set a
  selection-tint on the root background without killing touch feedback.
  Matches the same pattern used by item_tree_leaf.xml in Topics.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:foreground="?attr/selectableItemBackground">

    <!-- ── Main row ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/btnInlinePlay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="?attr/colorAccent" />

        <TextView
            android:id="@+id/tvNewBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_new_badge"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="15sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="-90"
            app:tint="?attr/colorTextSecondary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ── Expandable controls ────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/expandedControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:background="?attr/colorControlsTray">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceElevated"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRename"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Rename"
                android:textSize="11sp"
                android:textColor="?attr/colorTextPrimary"
                app:icon="@drawable/ic_rename"
                app:iconSize="16dp"
                app:iconTint="?attr/colorTextPrimary"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMove"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Move"
                android:textSize="11sp"
                android:textColor="?attr/colorTextPrimary"
                app:icon="@drawable/ic_move"
                app:iconSize="16dp"
                app:iconTint="?attr/colorTextPrimary"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Delete"
                android:textSize="11sp"
                android:textColor="?attr/colorDestructive"
                app:icon="@drawable/ic_delete"
                app:iconSize="16dp"
                app:iconTint="?attr/colorDestructive"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <com.treecast.app.ui.common.TopicPickerView
            android:id="@+id/inlineTopicPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>