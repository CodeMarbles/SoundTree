<?xml version="1.0" encoding="utf-8"?>
<!--
  Recording row — unified layout for all Recording list contexts.

  Used by RecordingsAdapter in:
    • All Recordings tab   (showTopicIcon = true  → tvTopicIcon visible)
    • Inbox / Unsorted tab (showTopicIcon = false → tvTopicIcon gone)
    • Topic Details tab    (showTopicIcon = false → tvTopicIcon gone)

  The old expand tray (expandedControls, ivChevron, btnRename, btnMove,
  btnDelete, inlineTopicPicker) has been removed. Actions are now surfaced
  via long-press or the ivOverflow (⋮) button, both triggering a PopupMenu.

  NOTE: ic_overflow should be a 24dp "more_vert" vector asset.
  Add via Android Studio → New → Vector Asset → search "more_vert".
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:foreground="?attr/selectableItemBackground">

    <!-- ── Main row ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <!-- Play / Pause button -->
        <ImageView
            android:id="@+id/btnInlinePlay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="?attr/colorAccent" />

        <!-- Topic icon — shown only when showTopicIcon=true (All Recordings context).
             Set by adapter; hidden by default to keep non-All rows clean. -->
        <TextView
            android:id="@+id/tvTopicIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="16sp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:visibility="gone" />

        <!-- NEW badge — shown for recordings < 30 min old -->
        <TextView
            android:id="@+id/tvNewBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"
            android:background="@drawable/bg_new_badge"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- Title + meta — takes all remaining horizontal space -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="15sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/tvMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Overflow ⋮ button — tappable alternative to long-press.
             contentDescription provides TalkBack label; the adapter also
             registers named AccessibilityActions on the row itself for
             full swipe-gesture support. -->
        <ImageView
            android:id="@+id/ivOverflow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_overflow"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Recording options"
            app:tint="?attr/colorTextSecondary" />

    </LinearLayout>

</LinearLayout>