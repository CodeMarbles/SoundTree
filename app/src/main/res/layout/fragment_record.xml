<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <!-- ════════════════════════════════════════════════════════════════
             Content area — weighted vertical LinearLayout so that
             MultiLineWaveformView fills all remaining space between the
             fixed-height controls and the pinned bottom area.

             No NestedScrollView here: MultiLineWaveformView contains its own
             RecyclerView which handles vertical scrolling within the waveform
             window. Wrapping a RecyclerView in a NestedScrollView defeats
             RecyclerView recycling and inflates all lines simultaneously.
             ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/recordContentArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPinnedArea">

        <!-- ── Compound header ────────────────────────────────────────
             topic zone + recording name zone.
             ─────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/compoundHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <!-- Topic picker zone (always visible) -->
            <LinearLayout
                android:id="@+id/topicHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="4dp"
                android:paddingEnd="2dp">

                <TextView
                    android:id="@+id/tvRecordTopicIcon"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:text="@string/topic_emoji_unsorted"
                    android:textSize="18sp"
                    android:includeFontPadding="false"
                    android:background="?attr/colorSurfaceBase"
                    android:backgroundTint="?attr/colorSurfaceBase"
                    android:layerType="software" />

                <TextView
                    android:id="@+id/tvRecordTopicName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/topic_label_unsorted"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Thin vertical divider — GONE in IDLE -->
            <View
                android:id="@+id/headerDivider"
                android:layout_width="1dp"
                android:layout_height="30dp"
                android:layout_marginHorizontal="10dp"
                android:background="?attr/colorSurfaceElevated"
                android:visibility="gone" />

            <!-- Recording name zone (GONE in IDLE) -->
            <LinearLayout
                android:id="@+id/recordingNameZone"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="4dp"
                android:paddingStart="2dp"
                android:visibility="invisible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/record_label_name_header"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecordingName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="—"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- Input source picker button (always visible) -->
            <ImageButton
                android:id="@+id/btnInputSource"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="end"
                android:padding="7dp"
                android:src="@drawable/ic_audio_source"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/record_btn_input_source_cd"
                app:tint="?attr/colorTextSecondary" />

        </LinearLayout>

        <!-- Header bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceElevated" />

        <!-- ── Waveform + timer overlay ────────────────────────────────
             Placeholder scrolling waveform (WaveformView) + timer.
             Will be replaced with a different visualizer once
             MultiLineWaveformView integration is complete.
             ─────────────────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/waveformFrame"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="10dp"
            android:background="?attr/colorSurfaceBase">

            <app.treecast.ui.record.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0:00"
                android:textSize="40sp"
                android:textColor="?attr/colorTextPrimary"
                android:fontFamily="monospace"
                android:letterSpacing="0.03"
                android:includeFontPadding="false" />

        </FrameLayout>

        <!-- ── Primary controls row ───────────────────────────────────
             Unchanged — Cancel / Record circle / Save.
             ─────────────────────────────────────────────────────── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/primaryControlsContainer"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp">

                <!-- Cancel — fills left of circle, shorter height, boxy corners -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/record_btn_cancel"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="?attr/colorActionCancel"
                    android:visibility="gone"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_cancel_x"
                    app:iconSize="20dp"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnRecord"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tvCancelHint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/record_label_cancel_hint"
                    android:textColor="#AAFFFFFF"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.1"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/btnCancel"
                    app:layout_constraintStart_toStartOf="@id/btnCancel"
                    app:layout_constraintEnd_toEndOf="@id/btnCancel"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- ● Record / Pause / Resume — true circle, 80 dp
                     Background tint, icon, text label, and stroke width are
                     ALL managed in RecordFragment.updateUiForState():
                       IDLE      → red fill (colorRecordActive), strokeWidth=2dp,
                                   icon=ic_record_circle, text="REC"
                       RECORDING → yellow fill (colorRecordPause), strokeWidth=0,
                                   icon=ic_pause, text="PAUSE"
                       PAUSED    → blue fill (colorAccent), strokeWidth=2dp,
                                   icon=ic_resume_circle, text="RESUME"             -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRecord"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/record_btn_rec"
                    android:textColor="@color/white"
                    android:textSize="22dp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:backgroundTint="?attr/colorRecordActive"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    app:iconTint="@color/white"
                    app:cornerRadius="40dp"
                    app:strokeColor="?attr/colorRecordButtonBorder"
                    app:strokeWidth="1.5dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- Save — fills right of circle, shorter height, boxy corners -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/record_btn_save"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="?attr/colorActionSave"
                    android:visibility="gone"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_save_check_wave"
                    app:iconSize="20dp"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:layout_constraintStart_toEndOf="@id/btnRecord"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── Multi-line waveform ────────────────────────────────────
             Fills all remaining space. Its internal RecyclerView scrolls
             vertically within this window — no outer scroll container
             needed or wanted.

             showPlayedSplit=false: no playhead on the Record tab.
             secondsPerLine configured in RecordFragment.setupMultiLineWaveform().
             ─────────────────────────────────────────────────────── -->
        <app.treecast.ui.waveform.MultiLineWaveformView
            android:id="@+id/multiLineWaveformView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════
         Pinned bottom area
         Contains the extended mark controls (GONE until mark selected)
         stacked above the mark / lock row (GONE in IDLE).
         The NestedScrollView is constrained to the top of this view.
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomPinnedArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Extended mark controls ─────────────────────────────────
             Slides in above the mark button when a mark is freshly
             dropped (auto-selected) or will be selected in a future
             waveform-tap interaction.

             Contents (left → right):
               tvMarkTimestamp   — monospace timestamp of selected mark
               [spacer]
               btnMarkNudgeBack  — shift mark earlier
               btnMarkNudgeForward — shift mark later
               btnMarkDelete     — delete selected mark (dismisses panel)
               btnMarkConfirm    — UI-only confirm: deselects mark,
                                   hides this panel, re-enables nudge
                                   lock (no data written)
             ─────────────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/markExtendedControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            app:cardBackgroundColor="?attr/colorSurfaceBase"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp">

                <!-- Timestamp of selected mark -->
                <TextView
                    android:id="@+id/tvMarkTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="?attr/colorMarkSelected"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_pill_teal_stroke"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp" />

                <!-- Flexible spacer -->
                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Nudge earlier -->
                <ImageView
                    android:id="@+id/btnMarkNudgeBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="2dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_mark_nudge_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorMarkSelected"
                    android:contentDescription="@string/mark_cd_nudge_back" />

                <!-- Nudge later -->
                <ImageView
                    android:id="@+id/btnMarkNudgeForward"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="2dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_mark_nudge_forward"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorMarkSelected"
                    android:contentDescription="@string/mark_cd_nudge_fwd" />

                <!-- Delete mark -->
                <ImageView
                    android:id="@+id/btnMarkDelete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="4dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorMarkSelected"
                    android:contentDescription="@string/mark_cd_delete" />

                <!-- Confirm / dismiss (UI-only: deselects mark, hides panel) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMarkConfirm"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorMarkSelected"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="0dp"
                    android:contentDescription="@string/mark_cd_confirm">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:scaleType="fitCenter" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Mark / Lock row ────────────────────────────────────────
             Pinned to the bottom of the screen, GONE in IDLE state.
             Lock is now icon-only with a boxy corner radius (10dp).
             Mark button fills the remaining width with icon + text
             side-by-side (no stacking).
             ─────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/markLockContainer"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <!-- Lock screen — icon only, boxy rounded rect -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnLockScreen"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorActionLockScreen"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_lock"
                    app:tint="?attr/colorStatusLockScreen"
                    android:scaleType="fitCenter" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Mark — icon + text, horizontal, fills remaining width -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnDropMark"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/mark_btn_add"
                app:cardBackgroundColor="?attr/colorMarkAction"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                android:contentDescription="@string/mark_cd_add" >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="7dp"
                        android:src="@drawable/ic_mark"
                        app:tint="#FFFFFF"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mark_btn_add"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>