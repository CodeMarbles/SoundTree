<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Main row ──────────────────────────────────────────────── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:paddingVertical="4dp"
        android:paddingEnd="16dp"
        android:foreground="?attr/selectableItemBackground">

        <View
            android:id="@+id/colorBar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="@string/topic_emoji_default"
            android:textSize="22sp"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/colorBar"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvIcon"
            app:layout_constraintEnd_toStartOf="@id/tvCount"
            android:layout_marginStart="12dp" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivChevron"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="-90"
            app:tint="?attr/colorTextSecondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── Expandable controls ───────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/expandedControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="?attr/colorControlsTray">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceElevated"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIcon"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/topic_btn_icon"
                android:textSize="11sp"
                android:textColor="?attr/colorTextPrimary"
                app:icon="@drawable/ic_circle"
                app:iconSize="14dp"
                app:iconTint="?attr/colorTextPrimary"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRename"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/common_btn_rename"
                android:textSize="11sp"
                android:textColor="?attr/colorTextPrimary"
                app:icon="@drawable/ic_rename"
                app:iconSize="16dp"
                app:iconTint="?attr/colorTextPrimary"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/common_btn_delete"
                android:textSize="11sp"
                android:textColor="?attr/colorDestructive"
                app:icon="@drawable/ic_delete"
                app:iconSize="16dp"
                app:iconTint="?attr/colorDestructive"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetails"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/topic_btn_details"
                android:textSize="11sp"
                android:textColor="?attr/colorTextPrimary"
                app:iconSize="16dp"
                app:iconTint="?attr/colorTextPrimary"
                app:iconGravity="textStart"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>