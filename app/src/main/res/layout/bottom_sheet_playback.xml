<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/surface_light"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <!-- Recording title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:maxLines="2"
        android:layout_marginBottom="4dp" />

    <!-- Duration -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_dim"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Seek bar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progressTint="@color/accent"
        android:thumbTint="@color/accent"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- Playback controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRewind"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="−15"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:cornerRadius="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="▶"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/accent"
            app:cornerRadius="36dp"
            android:layout_marginHorizontal="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForward"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="+15"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:cornerRadius="30dp" />

    </LinearLayout>

    <!-- Favourite toggle -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFavourite"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="❤️  Add to Favourites"
        android:textColor="@color/text_primary"
        app:strokeColor="@color/surface_light"
        app:cornerRadius="24dp"
        android:layout_marginBottom="4dp" />

    <!-- Category picker — move this recording while listening -->
    <com.treecast.app.ui.common.CategoryPickerView
        android:id="@+id/categoryPicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
