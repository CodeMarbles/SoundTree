<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_backup_log_detail.xml
  Full detail view for a single BackupLogEntity.
  Inflated by BackupLogDetailDialog; binding class = DialogBackupLogDetailBinding.

  Structure (ScrollView → vertical LinearLayout):
    1. Title row: volume label + status chip
    2. Date subtitle
    3. Divider
    4. Metadata rows: trigger · duration · files · bytes · database · [error message]
    5. Divider
    6. Events header + "Show milestones" toggle
    7. containerEvents — LinearLayout populated dynamically with ItemBackupLogEventBinding
    8. tvEventsEmpty  — visible when the event list is empty
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── 1. Title row ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvDetailVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="USB Drive" />

            <!--
                Status chip — background + text set from BackupLogDetailDialog.bindHeader().
                Uses same GradientDrawable pill approach as item_backup_log_row.xml.
            -->
            <TextView
                android:id="@+id/tvDetailStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginStart="12dp"
                tools:text="Success"
                tools:background="#2A7A3B" />

        </LinearLayout>

        <!-- ── 2. Date subtitle ───────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="13sp"
            tools:text="Mar 31, 2026 · 2:14 PM" />

        <!-- ── 3. Divider ─────────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceElevated"
            android:layout_marginHorizontal="24dp" />

        <!-- ── 4. Metadata rows ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <!-- Trigger -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_trigger_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailTrigger"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    tools:text="On Connect" />
            </LinearLayout>

            <!-- Duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_duration_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    tools:text="1m 43s" />
            </LinearLayout>

            <!-- Files (copied · skipped · failed) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_files_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailFiles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    tools:text="12 copied · 0 skipped · 0 failed" />
            </LinearLayout>

            <!-- Data copied (bytes) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_bytes_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailBytes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    tools:text="148.3 MB" />
            </LinearLayout>

            <!-- Database -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_db_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailDb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="13sp"
                    tools:text="Backed up" />
            </LinearLayout>

            <!--
                Top-level error message — only shown when status = FAILED.
                visibility=gone by default; set to VISIBLE in bindMetadata() when
                errorMessage is non-null and status == BackupStatus.FAILED.
            -->
            <LinearLayout
                android:id="@+id/rowDetailErrorMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_log_detail_error_message_label"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvDetailErrorMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorError"
                    android:textSize="13sp"
                    android:maxWidth="200dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    tools:text="Fatal: could not access destination" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── 5. Divider before events ──────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSurfaceElevated"
            android:layout_marginHorizontal="24dp" />

        <!-- ── 6. Events header + toggle ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="8dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/backup_log_detail_events_title"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <!--
                Toggles between showing WARNING+ERROR only (default) and
                including INFO milestone rows. Text is updated from code when
                toggled. Initially shows the "show" label.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleInfo"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_log_detail_btn_show_info"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

        <!-- ── 7. Dynamic event list ─────────────────────────────────────────── -->
        <!--
            Populated by BackupLogDetailDialog.bindEvents() each time the
            observed event flow emits. Items are ItemBackupLogEventBinding rows.
        -->
        <LinearLayout
            android:id="@+id/containerEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- ── 8. Empty state ─────────────────────────────────────────────────── -->
        <!--
            Shown when the current event filter (problems-only or all-events)
            returns an empty list. Hidden whenever at least one event is rendered.
        -->
        <TextView
            android:id="@+id/tvEventsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/backup_log_detail_no_events"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="13sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

</ScrollView>