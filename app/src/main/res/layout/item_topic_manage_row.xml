<?xml version="1.0" encoding="utf-8"?>
<!--
  Single topic row for the Topics Management tab.
  Styled to match TopicPickerView: indent → icon → name → count → chevron.
  No color bar. No action buttons. All management via long-press PopupMenu.
  Depth-based indentation is applied programmatically (20dp per level).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingEnd="4dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- Topic icon (emoji) -->
    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="18sp" />

    <!-- Topic name -->
    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="?attr/colorTextPrimary"
        android:textSize="15sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginStart="10dp" />

    <!-- Recording count: "5 RECORDINGS" — hidden when 0 -->
    <TextView
        android:id="@+id/tvCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="2dp" />

    <!-- Collapse/expand chevron — only shown when topic has child topics -->
    <ImageView
        android:id="@+id/ivChevron"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_chevron_down"
        android:padding="9dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorTextSecondary" />

</LinearLayout>