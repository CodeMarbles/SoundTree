<?xml version="1.0" encoding="utf-8"?>
<!--
  Single topic row for the Topics Management tab.
  Styled to match TopicPickerView: icon → name → ·count → chevron → move → DETAILS
  Depth-based indentation is applied programmatically (20dp per level).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:paddingEnd="8dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- Left color accent bar -->
    <View
        android:id="@+id/colorBar"
        android:layout_width="4dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Topic icon (emoji) -->
    <TextView
        android:id="@+id/tvIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/colorBar" />

    <!-- Topic name -->
    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorTextPrimary"
        android:textSize="15sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginStart="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvIcon"
        app:layout_constraintEnd_toStartOf="@id/tvCount" />

    <!-- Recording count ·N (hidden when 0) -->
    <TextView
        android:id="@+id/tvCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorTextSecondary"
        android:textSize="12sp"
        android:layout_marginEnd="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivChevron" />

    <!-- Collapse/expand chevron (only shown when topic has child topics) -->
    <ImageView
        android:id="@+id/ivChevron"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_chevron_down"
        android:padding="9dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorTextSecondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMove" />

    <!-- Move/reparent icon button -->
    <ImageButton
        android:id="@+id/btnMove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_move"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Move topic"
        app:tint="?attr/colorTextSecondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDetails" />

    <!-- DETAILS button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDetails"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="DETAILS"
        android:textSize="10sp"
        android:textColor="?attr/colorAccent"
        android:letterSpacing="0.05"
        android:minWidth="0dp"
        android:paddingHorizontal="8dp"
        app:cornerRadius="6dp"
        app:strokeColor="?attr/colorAccent"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>