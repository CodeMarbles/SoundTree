<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_listen.xml — Listen Tab refactor
  Root is ConstraintLayout (replaces NestedScrollView).

  Five constraint-anchored zones:
    A. pinnedTopArea    — header + seek row + transport + stubs
    B. multiLineWaveform — fills space between A and C
    C. splitterBar      — 28dp, pinned to splitterGuideline
    D. markTimestampList — fills space between C and E
    E. pinnedBottomArea — mark extended controls card + action row

  A ConstraintLayout Group with id=playerContent references all five zone
  views so that updateUi() can toggle them with a single visibility call,
  matching the old binding.playerContent pattern.

  Empty state is an unconstrained centered overlay on top of everything.
-->

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/splitterGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.62" />

    <!-- ════════════════════════════════════════════════════════════════
         Zone A — Pinned top area
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/pinnedTopArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Header row: icon | category+title | overflow | date+duration ── -->
        <LinearLayout
            android:id="@+id/topicHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <!-- Topic icon -->
            <TextView
                android:id="@+id/tvTopicIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:includeFontPadding="false"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

            <!-- Category + title — weight=1 takes remaining space -->
            <LinearLayout
                android:id="@+id/layoutTitleArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="2dp">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- 3-dot overflow menu -->
            <ImageView
                android:id="@+id/ivListenOverflow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_overflow"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/recording_cd_overflow"
                app:tint="?attr/colorTextSecondary" />

            <!-- Date + duration + file size meta column — right-aligned, small -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvRecordedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Seek bar ──────────────────────────────────────────────── -->
        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="0dp"
            android:progressTint="?attr/colorAccent"
            android:thumbTint="?attr/colorAccent" />

        <!-- ── Time labels row ───────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/timeLabelsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                tools:text="0:00"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                tools:text="-0:00"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- ── Consolidated transport row ────────────────────────────────
             Single row containing speed stub | jump/skip | play | skip/jump
             | sleep stub. gravity=bottom means all children bottom-align to
             the play button's lower edge. Speed/sleep TextButtons being
             shorter than the icon buttons naturally sit "lower" visually.
             ─────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="2dp"
            android:paddingBottom="4dp">

            <!-- Speed stub — hugs left edge -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackSpeed"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="1x"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp" />

            <!-- Left spacer: pushes central controls to centre -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Jump to previous mark -->
            <ImageView
                android:id="@+id/btnJumpPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_jump_prev_mark"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mark_cd_jump_prev"
                app:tint="?attr/colorMarkDefault" />

            <!-- Skip back -->
            <ImageView
                android:id="@+id/btnSkipBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_skip_back"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/listen_cd_skip_back"
                app:tint="?attr/colorTextPrimary" />

            <!-- Play / Pause — matches skip button size; corner radius = half width -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayPause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:backgroundTint="?attr/colorAccent"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text=""
                android:contentDescription=""
                app:icon="@drawable/ic_play"
                app:iconPadding = "0dp"
                app:iconSize="22dp"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                app:cornerRadius="24dp" />

            <!-- Skip forward -->
            <ImageView
                android:id="@+id/btnSkipForward"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_skip_forward"
                android:padding="10dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/listen_cd_skip_forward"
                app:tint="?attr/colorTextPrimary" />

            <!-- Jump to next mark -->
            <ImageView
                android:id="@+id/btnJumpNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_jump_next_mark"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/mark_cd_jump_next"
                app:tint="?attr/colorMarkDefault" />

            <!-- Right spacer: symmetric with left spacer -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Sleep timer stub — hugs right edge -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSleepTimer"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="@string/listen_btn_sleep_timer"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════
         Zone B — MultiLineWaveformView
         ════════════════════════════════════════════════════════════════ -->
    <app.soundtree.ui.waveform.MultiLineWaveformView
        android:id="@+id/multiLineWaveform"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="14dp"
        app:layout_constraintTop_toBottomOf="@id/pinnedTopArea"
        app:layout_constraintBottom_toTopOf="@id/splitterBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ════════════════════════════════════════════════════════════════
         Zone C — Splitter bar
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/splitterBar"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurfaceElevated"
        app:layout_constraintTop_toTopOf="@id/splitterGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnSnapDown"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_down"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/listen_cd_expand_waveform"
            app:tint="?attr/colorTextSecondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_drag_handle_pill" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/btnSnapUp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_up"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/listen_cd_expand_marks"
            app:tint="?attr/colorTextSecondary" />

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════
         Zone D.5 — Inline seek strip (SNAP_UP only)
         [position | seekbar | remaining] in a single row, sitting between
         the splitter bar and the mark chip scroller.
         GONE in SNAP_DOWN; VISIBLE in SNAP_UP via applyChipLayoutMode().
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/seekBarAreaBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/splitterBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPositionBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            tools:text="0:00"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:layout_marginEnd="6dp" />

        <SeekBar
            android:id="@+id/seekBarBottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressTint="?attr/colorAccent"
            android:thumbTint="?attr/colorAccent" />

        <TextView
            android:id="@+id/tvRemainingBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            tools:text="-0:00"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Barrier sits at the bottom of seekBarAreaBottom when VISIBLE,
         falls back to splitterBar bottom when seekBarAreaBottom is GONE.
         markChipScroller always constrains to this, never to either view directly. -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/seekStripBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="splitterBar,seekBarAreaBottom" />

    <!-- ════════════════════════════════════════════════════════════════
         Zone D — Mark chip area
         HorizontalScrollView + FlowLayout, unchanged from rev 2.
         ════════════════════════════════════════════════════════════════ -->
    <HorizontalScrollView
        android:id="@+id/markChipScroller"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="false"
        app:layout_constraintTop_toBottomOf="@id/seekStripBarrier"
        app:layout_constraintBottom_toTopOf="@id/pinnedBottomArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <app.soundtree.ui.listen.FlowLayout
            android:id="@+id/markTimestampList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

    </HorizontalScrollView>

    <!-- ════════════════════════════════════════════════════════════════
         Zone E — Pinned bottom area
         7a markExtendedControls card removed entirely.
         Only the 7b mark action row remains.
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/pinnedBottomArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 7b. Mark action row — always visible -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left half: nudge / delete / confirm -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp">

                <ImageView
                    android:id="@+id/btnMarkNudgeBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_mark_nudge_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/mark_cd_nudge_back"
                    app:tint="?attr/colorTextSecondary" />

                <!-- Nudge amount label — updated dynamically from markNudgeSecs -->
                <TextView
                    android:id="@+id/tvMarkNudgeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="20dp"
                    android:gravity="center"
                    android:text="5s"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="2dp" />

                <ImageView
                    android:id="@+id/btnMarkNudgeForward"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="5dp"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_mark_nudge_forward"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/mark_cd_nudge_fwd"
                    app:tint="?attr/colorTextSecondary" />

                <ImageView
                    android:id="@+id/btnMarkDelete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/mark_cd_delete"
                    app:tint="?attr/colorTextSecondary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMarkConfirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorTextSecondary"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    android:contentDescription="@string/mark_cd_confirm" >

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:src="@drawable/ic_check"
                        app:tint="#FFFFFF"
                        android:scaleType="fitCenter" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Right half: MARK pill button -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddMark"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/mark_btn_add"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/white"
                    android:backgroundTint="?attr/colorMarkDefault"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_mark"
                    app:iconSize="16dp"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    app:cornerRadius="24dp"
                    android:contentDescription="@string/mark_cd_add" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════
         Player content Group
         ════════════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/playerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:constraint_referenced_ids="pinnedTopArea,multiLineWaveform,splitterBar,markChipScroller,pinnedBottomArea" />

    <!-- ════════════════════════════════════════════════════════════════
         Empty state
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/listen_empty_emoji"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/listen_empty_heading"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/listen_empty_body"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="14sp"
            android:textAlignment="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>