<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <!-- ── Empty state ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎧"
                android:textSize="56sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nothing playing yet"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap play on a recording in the Library to start listening."
                android:textColor="?attr/colorTextSecondary"
                android:textSize="14sp"
                android:textAlignment="center" />

        </LinearLayout>

        <!-- ── Player content ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/playerContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Waveform -->
            <com.treecast.app.ui.listen.PlaybackWaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="20dp" />

            <!--
                Category label above the recording title.
                Shown in colorTextSecondary when categorised;
                in colorStatusRecordingLabel (muted amber) when in Inbox.
            -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="?attr/colorTextSecondary"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <!-- Recording title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="2"
                android:layout_marginBottom="4dp" />

            <!-- Date + Duration on one row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvRecordedAt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Seek bar -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="?attr/colorAccent"
                android:thumbTint="?attr/colorAccent"
                android:layout_marginBottom="4dp" />

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-0:00"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Transport controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="28dp">

                <ImageView
                    android:id="@+id/btnSkipBack"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_skip_back"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorTextPrimary" />

                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_play"
                    android:padding="14dp"
                    android:backgroundTint="?attr/colorAccent"
                    android:background="@drawable/bg_circle_accent"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/white"
                    android:layout_marginHorizontal="20dp" />

                <ImageView
                    android:id="@+id/btnSkipForward"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_skip_forward"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="?attr/colorTextPrimary" />

            </LinearLayout>

            <!-- ╔══════════════════════════════════════╗ -->
            <!-- ║  Mini tab panel (Categorize | Marks) ║ -->
            <!-- ╚══════════════════════════════════════╝ -->

            <!-- Mini tab bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="?attr/colorSurfaceBase"
                android:layout_marginBottom="0dp">

                <TextView
                    android:id="@+id/tabCategorize"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Categorize"
                    android:textSize="13sp"
                    android:textColor="?attr/colorTextPrimary"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurfaceElevated" />

                <TextView
                    android:id="@+id/tabMarks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Marks"
                    android:textSize="13sp"
                    android:textColor="?attr/colorTextSecondary"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Active tab indicator bar -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?attr/colorSurfaceBase"
                android:layout_marginBottom="12dp">

                <View
                    android:id="@+id/tabIndicator"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="?attr/colorAccent" />

            </FrameLayout>

            <!-- Page 0: Categorize -->
            <com.treecast.app.ui.common.TopicPickerView
                android:id="@+id/topicPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible" />

            <!-- Page 1: Marks -->
            <LinearLayout
                android:id="@+id/marksPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorMarkSurface"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <!-- ── Chip flow area ──────────────────────────── -->
                <com.treecast.app.ui.listen.FlowLayout
                    android:id="@+id/markTimestampList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="36dp"
                    android:paddingBottom="8dp" />

                <!-- ── Button row ──────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp">

                    <!-- Delete — less prominent, left side -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteMark"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delete"
                        android:textSize="13sp"
                        android:textColor="?attr/colorDestructive"
                        android:enabled="false"
                        android:alpha="0.4"
                        app:icon="@drawable/ic_delete"
                        app:iconSize="16dp"
                        app:iconTint="?attr/colorDestructive"
                        app:iconGravity="textStart"
                        app:cornerRadius="8dp" />

                    <!-- Spacer pushes Mark button to the right -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Mark — prominent filled dark-pink button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddMark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="＋ Mark"
                        android:textSize="15sp"
                        android:textColor="@color/white"
                        android:backgroundTint="?attr/colorMarkAction"
                        app:icon="@drawable/ic_mark"
                        app:iconSize="18dp"
                        app:iconTint="@color/white"
                        app:iconGravity="textStart"
                        app:cornerRadius="20dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>