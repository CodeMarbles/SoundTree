<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <!-- ── Empty state ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎧"
                android:textSize="56sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nothing playing yet"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap play on a recording in the Library to start listening."
                android:textColor="?attr/colorTextSecondary"
                android:textSize="14sp"
                android:textAlignment="center" />

        </LinearLayout>

        <!-- ── Player content ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/playerContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/topicHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="visible"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvTopicIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="40sp"
                    android:lineHeight="48sp"
                    android:layout_marginEnd="12dp"
                    android:includeFontPadding="false" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="2" />

                </LinearLayout>

                <!-- Chevron hints that the header is tappable -->
                <ImageView
                    android:id="@+id/ivTopicHeaderChevron"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_chevron_down"
                    android:rotation="-90"
                    app:tint="?attr/colorTextSecondary" />

            </LinearLayout>

            <!-- Waveform -->
            <com.treecast.app.ui.listen.PlaybackWaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="20dp" />

            <!-- Date + Duration on one row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvRecordedAt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Seek bar -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="?attr/colorAccent"
                android:thumbTint="?attr/colorAccent"
                android:layout_marginBottom="4dp" />

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvPosition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-0:00"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Transport controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="28dp">

                <!-- Skip back (fixed scrub interval) -->
                <ImageView
                    android:id="@+id/btnSkipBack"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_skip_back"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Skip back"
                    app:tint="?attr/colorTextPrimary" />

                <!-- Jump to previous mark -->
                <ImageView
                    android:id="@+id/btnJumpPrev"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="8dp"
                    android:src="@drawable/ic_jump_prev_mark"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Jump to previous mark"
                    app:tint="?attr/colorMarkDefault" />

                <!-- Play / Pause -->
                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_play"
                    android:padding="14dp"
                    android:backgroundTint="?attr/colorAccent"
                    android:background="@drawable/bg_circle_accent"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Play / Pause"
                    app:tint="@color/white" />

                <!-- Jump to next mark -->
                <ImageView
                    android:id="@+id/btnJumpNext"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="8dp"
                    android:src="@drawable/ic_jump_next_mark"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Jump to next mark"
                    app:tint="?attr/colorMarkDefault" />

                <!-- Skip forward (fixed scrub interval) -->
                <ImageView
                    android:id="@+id/btnSkipForward"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_skip_forward"
                    android:padding="10dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Skip forward"
                    app:tint="?attr/colorTextPrimary" />

            </LinearLayout>

            <!-- Page 1: Marks -->
            <LinearLayout
                android:id="@+id/marksPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorMarkSurface"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:visibility="visible">

                <!-- ── Chip flow area ──────────────────────────── -->
                <com.treecast.app.ui.listen.FlowLayout
                    android:id="@+id/markTimestampList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="36dp"
                    android:paddingBottom="8dp" />

                <!-- ── Button row ──────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp">

                    <!-- Delete — less prominent, left side -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteMark"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delete"
                        android:textSize="13sp"
                        android:textColor="?attr/colorTextSecondary"
                        android:enabled="false"
                        app:icon="@drawable/ic_delete"
                        app:iconSize="16dp"
                        app:iconTint="?attr/colorTextSecondary"
                        app:iconGravity="textStart"
                        app:cornerRadius="8dp" />

                    <!-- Nudge back ← -->
                    <ImageView
                        android:id="@+id/btnMarkNudgeBack"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_mark_nudge_back"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:enabled="false"
                        android:contentDescription="Move mark back"
                        app:tint="?attr/colorMarkSelected" />

                    <!-- Commit ✓ -->
                    <ImageView
                        android:id="@+id/btnMarkCommit"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="2dp"
                        android:src="@drawable/ic_check"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:enabled="false"
                        android:contentDescription="Confirm mark position"
                        app:tint="?attr/colorMarkSelected" />

                    <!-- Spacer pushes Mark button to the right -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Nudge forward → -->
                    <ImageView
                        android:id="@+id/btnMarkNudgeForward"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="2dp"
                        android:src="@drawable/ic_mark_nudge_forward"
                        android:padding="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:enabled="false"
                        android:contentDescription="Move mark forward"
                        app:tint="?attr/colorMarkSelected" />

                    <!-- Spacer pushes Mark button to the right -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- Mark — prominent filled pill -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddMark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:textColor="@color/white"
                        android:backgroundTint="?attr/colorMarkAction"
                        app:icon="@drawable/ic_mark"
                        app:iconSize="16dp"
                        app:iconTint="@color/white"
                        app:iconGravity="textStart"
                        app:cornerRadius="20dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>