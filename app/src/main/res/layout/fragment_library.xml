<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/tilePager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dividerSubNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/dividerSubNav"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/colorSurfaceElevated"
        app:layout_constraintBottom_toTopOf="@id/librarySubNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Compact 5-tab sub-nav ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/librarySubNav"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="?attr/colorSurfaceBase"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/subNavAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ALL"
            android:textSize="11sp"
            android:textColor="?attr/colorTextSecondary"
            android:letterSpacing="0.05"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceElevated" />

        <TextView
            android:id="@+id/subNavUnsorted"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="UNSORTED"
            android:textSize="11sp"
            android:textColor="?attr/colorTextSecondary"
            android:letterSpacing="0.05"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceElevated" />

        <TextView
            android:id="@+id/subNavTopics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="TOPICS"
            android:textSize="11sp"
            android:textColor="?attr/colorTextSecondary"
            android:letterSpacing="0.05"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceElevated" />

        <TextView
            android:id="@+id/subNavRecordings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ORGANIZE"
            android:textSize="11sp"
            android:textColor="?attr/colorTextSecondary"
            android:letterSpacing="0.05"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceElevated" />

        <TextView
            android:id="@+id/subNavDetails"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="DETAILS"
            android:textSize="11sp"
            android:textColor="?attr/colorTextSecondary"
            android:letterSpacing="0.05"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:alpha="0.35" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>