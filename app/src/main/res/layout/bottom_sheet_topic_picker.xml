<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceBase">

    <!-- ── Title row ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/tvPickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/topic_picker_title_select"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorSurfaceElevated" />

    <!-- ── Unsorted option ────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/rowUnsorted"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvNullRowIcon"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="📥"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvNullRowLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/topic_label_unsorted"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="14sp"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorSurfaceElevated"
        android:layout_marginHorizontal="16dp" />

    <!-- ── Topic tree ─────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTopics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp"
        android:clipToPadding="false" />

</LinearLayout>