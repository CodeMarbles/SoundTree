<?xml version="1.0" encoding="utf-8"?>
<!--
  Mini Player bar v4 — three-row layout.

  108dp layout:
    Row 1 (weight 18): recording title — full width, single line
    Row 2 (weight 52): skip-back | play/pause | skip-forward | [playback timeline]
    Row 3 (weight 38): playback time | spacer |
                       delete | nudge-back | jump-prev | [MARK] | jump-next | nudge-fwd | commit

  Moving the title to its own row gives the mark cluster in Row 3 the full
  width of the bar — no more cramping.

  Height bump from 96dp → 108dp; update LayoutElement.MINI_PLAYER in
  MainActivity.applyLayoutOrder() to match: (108 * dp).toInt()
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="108dp"
    android:background="?attr/colorMiniPlayerSurface"
    android:elevation="4dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Accent line — repositioned by MainActivity for layout order -->
    <View
        android:id="@+id/accentLine"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="?attr/colorAccent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/miniContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/accentLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Row 1: Recording title ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="18"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Now Playing: "
                android:textColor="?attr/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- ── Row 2: Transport controls + playback timeline ─────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="52"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- Skip back -->
            <ImageView
                android:id="@+id/btnMiniSkipBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_skip_back"
                android:padding="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Skip back"
                app:tint="?attr/colorTextPrimary" />

            <!-- Play / Pause -->
            <ImageView
                android:id="@+id/btnMiniPlayPause"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Play / Pause"
                app:tint="?attr/colorAccent" />

            <!-- Skip forward -->
            <ImageView
                android:id="@+id/btnMiniSkipForward"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_skip_forward"
                android:padding="5dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Skip forward"
                app:tint="?attr/colorTextPrimary" />

            <!-- Playback timeline — fills rest of Row 2 -->
            <com.treecast.app.ui.widget.MiniPlayerTimelineView
                android:id="@+id/miniPlayerTimeline"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- ── Row 3: Time (left) + mark cluster (right) ─────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="38"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <!-- Playback time — left aligned, mirrors recorder's elapsed -->
            <TextView
                android:id="@+id/tvMiniTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00 / 0:00"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <!-- Spacer pushes mark cluster to the right -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!--
              ════════════════════════════════════════════════
               MARK CLUSTER  (left → right)
               delete | nudge-back | jump-prev | MARK | jump-next | nudge-fwd | commit
              ════════════════════════════════════════════════
            -->

            <!-- Delete selected mark -->
            <ImageView
                android:id="@+id/btnMiniDeleteMark"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_delete"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="Delete selected mark"
                app:tint="?attr/colorDestructive" />

            <!-- Nudge mark back ← (outer ring) -->
            <ImageView
                android:id="@+id/btnMiniMarkNudgeBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mark_nudge_back"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="Move mark back"
                app:tint="?attr/colorMarkSelected" />

            <!-- Jump to previous mark (inner ring) -->
            <ImageView
                android:id="@+id/btnMiniJumpPrev"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_jump_prev_mark"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Jump to previous mark"
                app:tint="?attr/colorMarkDefault" />

            <!-- MARK pill — blue stroke = "listener's tool" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMiniAddMark"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="MARK"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:backgroundTint="?attr/colorMarkAction"
                app:icon="@drawable/ic_mark"
                app:iconSize="13dp"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                app:iconPadding="3dp"
                app:cornerRadius="15dp"
                app:strokeColor="?attr/colorAccent"
                app:strokeWidth="2dp"
                android:contentDescription="Add mark at current position" />

            <!-- Jump to next mark (inner ring) -->
            <ImageView
                android:id="@+id/btnMiniJumpNext"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_jump_next_mark"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Jump to next mark"
                app:tint="?attr/colorMarkDefault" />

            <!-- Nudge mark forward → (outer ring) -->
            <ImageView
                android:id="@+id/btnMiniMarkNudgeForward"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mark_nudge_forward"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="Move mark forward"
                app:tint="?attr/colorMarkSelected" />

            <!-- Confirm mark position -->
            <ImageView
                android:id="@+id/btnMiniMarkCommit"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_mark_nudge_commit"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:enabled="false"
                android:alpha="0.3"
                android:contentDescription="Confirm mark position"
                app:tint="?attr/colorMarkSelected" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>