<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_recording_details.xml
  Full-screen dialog showing details for a single recording.

  Sections (top → bottom):
    1. Top bar      — close (X) left, overflow (⋮) right
    2. Topic zone   — icon + name, tappable to change topic
    3. Title row    — play/pause toggle + recording name (tappable to rename)
    4. Metadata     — duration · date
    5. Divider
    6. Waveform     — condensed, read-only MultiLineWaveformView overview
    7. [Future]     — clips section placeholder

  Theme: Theme.TreeCast.FullscreenDialog (see themes.xml addition)
  Fragment class: RecordingDetailsDialogFragment
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <!-- ══════════════════════════════════════════════════════════════
         Top bar — close left, overflow right.
         Both are 48dp tap targets with borderless ripple.
         ══════════════════════════════════════════════════════════════ -->

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_close"
        android:padding="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/recording_details_cd_close"
        app:tint="?attr/colorTextSecondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp" />

    <ImageView
        android:id="@+id/btnOverflow"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_overflow"
        android:padding="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/recording_cd_overflow"
        app:tint="?attr/colorTextSecondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="4dp" />

    <!-- ══════════════════════════════════════════════════════════════
         Topic zone — icon pill + topic name, tappable.
         Matches the topicHeader pattern used in the Record and Listen
         tabs so the interaction is immediately recognisable.
         ══════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/topicHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnClose"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/tvTopicIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="@string/topic_emoji_unsorted"
            android:textSize="16sp"
            android:includeFontPadding="false"
            android:background="?attr/colorSurfaceBase" />

        <TextView
            android:id="@+id/tvTopicName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/topic_label_unsorted"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         Title row — play/pause toggle (left) + recording name (right).

         Play/pause:
           • ImageView with borderless ripple — keeps the row visually
             light while providing a clear 48dp tap target.
           • android:padding="12dp" pulls the icon inward, so the tap
             area extends well past the icon edge without visually
             encroaching on the title text.
           • Set src to ic_play / ic_pause in code based on nowPlaying.

         Recording name:
           • layout_weight="1" fills remaining horizontal space.
           • Tappable for rename (same pattern as topic name in
             TopicDetailsFragment).
           • Explicit paddingStart keeps text away from the play button's
             visual edge even though the button already has internal padding.
         ══════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/topicHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="2dp">

        <ImageView
            android:id="@+id/btnPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play"
            android:padding="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/mini_player_cd_play_pause"
            app:tint="?attr/colorAccent" />

        <TextView
            android:id="@+id/tvRecordingName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="4dp"
            android:paddingHorizontal="4dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         Metadata block — duration, file size, and recorded date/time.
         Two rows of labeled stat cells, indented to align with the
         recording name (68dp = 48dp button + 4dp margin + 16dp gap).
         ══════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/metaBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="68dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/titleRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 — Duration (left) | File Size (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Duration cell -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DURATION"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMetaDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="17sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- File Size cell -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FILE SIZE"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMetaFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="17sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Row 2 — Recorded date + time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECORDED"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMetaRecordedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="17sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Row 3 — File location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCATION"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMetaFilePath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         Divider above waveform section.
         ══════════════════════════════════════════════════════════════ -->

    <View
        android:id="@+id/dividerWaveform"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/colorSurfaceElevated"
        app:layout_constraintTop_toBottomOf="@id/metaBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════
         Waveform overview — condensed, read-only.

         Fixed height gives a predictable "postage stamp" view of the
         whole recording without triggering internal RecyclerView scroll.
         secondsPerLine is set in code to fit the full duration into the
         available lines; onTimeSelected is left null (no seek behaviour).

         The widget still renders marks if they are pushed — but for now
         the fragment will not push them. Leave as a future option.
         ══════════════════════════════════════════════════════════════ -->

    <com.treecast.app.ui.waveform.MultiLineWaveformView
        android:id="@+id/multiLineWaveform"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/dividerWaveform"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════════════
         [Future] Clips section.
         Add a section header TextView + RecyclerView here when clip
         extraction is implemented. Constrain the RecyclerView's top to
         multiLineWaveform's bottom and its bottom to parent bottom so
         it fills all remaining space.
         ══════════════════════════════════════════════════════════════ -->

</androidx.constraintlayout.widget.ConstraintLayout>