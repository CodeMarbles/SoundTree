<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App identity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌳  TreeCast"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal podcast · voice journal"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="32dp" />

        <!-- ── Appearance card ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingHorizontal="4dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceBase"
            app:cardCornerRadius="@dimen/settings_card_corner_radius"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- ── Theme ───────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Theme"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Follow system, or lock to light or dark"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- Three-way toggle: System / Light / Dark -->
                    <LinearLayout
                        android:id="@+id/themeToggleGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_picker"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/btnThemeSystem"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Auto"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnThemeLight"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Light"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btnThemeDark"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Dark"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:paddingHorizontal="10dp"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- ── UI Layout ───────────────── -->
                <LinearLayout
                    android:id="@+id/cardLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="?attr/colorSurfaceBase"
                    android:layout_marginBottom="12dp">

                    <!-- Section header row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Layout"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <!-- Show title bar toggle (inline with header) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Title bar"
                                android:textColor="?attr/colorTextSecondary"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchShowTitleBar"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Widget + Edit/Apply button row -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:cardBackgroundColor="?attr/colorSurfaceElevated"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="0dp"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="16dp">

                            <!-- Edit layout / Apply button -->
                            <TextView
                                android:id="@+id/btnEditLayout"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Edit layout"
                                android:textSize="13sp"
                                android:textColor="?attr/colorAccent"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="8dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true" />

                            <!-- Spacer -->
                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <!-- The reorder widget — fixed 170dp wide -->
                            <com.treecast.app.ui.settings.LayoutReorderWidget
                                android:id="@+id/layoutReorderWidget"
                                android:layout_width="170dp"
                                android:layout_height="wrap_content" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Playback card ─────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLAYBACK"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceBase"
            app:cardCornerRadius="@dimen/settings_card_corner_radius"
            app:cardElevation="0dp" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- ── Switch to Listen on play ───────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Switch to Listen on play"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatically open the Listen tab when playback starts"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAutoNavigate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- ── Jump to Library on save toggle ──────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jump to recording after saving"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Open Library and select the recording when you finish saving"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchJumpToLibrary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- ── Scrub Back length ───────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scrub Back"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seconds to jump back when ⏪ is tapped"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScrubBackMinus"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="−"
                        android:textSize="18sp"
                        android:textColor="?attr/colorTextPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:strokeColor="?attr/colorSurfaceElevated"
                        app:cornerRadius="18dp" />

                    <TextView
                        android:id="@+id/tvScrubBackSecs"
                        android:layout_width="48dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="15"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScrubBackPlus"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="?attr/colorTextPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:strokeColor="?attr/colorSurfaceElevated"
                        app:cornerRadius="18dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- ── Scrub Forward length ────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scrub Forward"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seconds to jump forward when ⏩ is tapped"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScrubForwardMinus"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="−"
                        android:textSize="18sp"
                        android:textColor="?attr/colorTextPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:strokeColor="?attr/colorSurfaceElevated"
                        app:cornerRadius="18dp" />

                    <TextView
                        android:id="@+id/tvScrubForwardSecs"
                        android:layout_width="48dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="15"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScrubForwardPlus"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textSize="18sp"
                        android:textColor="?attr/colorTextPrimary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        app:strokeColor="?attr/colorSurfaceElevated"
                        app:cornerRadius="18dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Storage card ──────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STORAGE"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceBase"
            app:cardCornerRadius="@dimen/settings_card_corner_radius"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Default recording storage"
                            android:textColor="?attr/colorTextPrimary"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New recordings will be saved here"
                            android:textColor="?attr/colorTextSecondary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Dynamic volume selector — populated by SettingsFragment -->
                <!-- Each volume gets a row injected at runtime via addStorageVolumeRow() -->
                <LinearLayout
                    android:id="@+id/storageVolumeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- Total used storage summary row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total used by TreeCast"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTotalUsed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Stats section ────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STATS"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceBase"
            app:cardCornerRadius="@dimen/settings_card_corner_radius"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Total recorded time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total recorded time"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTotalRecordedTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- Last session -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Last session"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvLastOpened"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- Listened count -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recordings listened"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvListenedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- Number of topics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Topics"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTopicCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSurfaceElevated"
                    android:layout_marginHorizontal="16dp" />

                <!-- Total storage used -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total storage used"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvStatsTotalStorage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>