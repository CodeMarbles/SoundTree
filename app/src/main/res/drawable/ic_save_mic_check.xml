<?xml version="1.0" encoding="utf-8"?>
<!--
  Save icon — microphone silhouette with green check badge.
  Semantics: "Recording saved / committed."
  Badge sits at top-right (cx≈17, cy≈6) with a generous
  radius so the check stays legible at 28–30dp.
  Leave imageTintList null so the two-color design shows through.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Mic capsule body -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M9,3 A3,3 0 0,1 15,3 L15,12 A3,3 0 0,1 9,12 Z" />

    <!-- Stand arc -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M5,12 Q5,18 12,18 Q19,18 19,12" />

    <!-- Stem -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M12,18 L12,22" />

    <!-- Badge circle (green fill, covers top-right of mic) -->
    <path
        android:fillColor="#2E7D32"
        android:pathData="M17,0.5 A5.5,5.5 0 1,1 17,11.5 A5.5,5.5 0 1,1 17,0.5 Z" />

    <!-- Badge checkmark (white) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M14.5,6 L16.4,8 L20,4" />

</vector>