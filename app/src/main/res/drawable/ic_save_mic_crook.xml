<?xml version="1.0" encoding="utf-8"?>
<!--
  Save icon — large green checkmark (dominant) with a small mic
  tucked into the upper crook of the check.

  Semantics: "done / recording saved" with the recording context
  embedded as a secondary glyph rather than a badge.

  Usage:
    - Leave imageTintList = null so the two-color design shows.
    - The checkmark uses #4CAF50 (Material Green 500). Swap to
      your app's green accent token if desired.
    - The mic uses #FFFFFF (contrast variant). For the monochromatic
      variant, replace all #FFFFFF stroke values with #81C784.

  Notes:
    - At ≤30dp: consider omitting the stand arc + stem paths
      (marked below) for a cleaner read at small sizes.
    - Mic capsule body is a rounded-rect expressed as a closed path.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- ── Large green checkmark (dominant element) ── -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#4CAF50"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M3,16 L9,22 L21,8" />

    <!-- ── Small mic in upper-left crook ── -->

    <!-- Mic capsule body (rounded rect: x=3.5 y=2 w=4 h=8 rx=2) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M5.5,2 H5.5 A2,2 0 0,1 7.5,4 V8 A2,2 0 0,1 5.5,10 H5.5 A2,2 0 0,1 3.5,8 V4 A2,2 0 0,1 5.5,2 Z" />

    <!-- Stand arc — omit at ≤30dp for cleaner result -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M1.5,10 Q1.5,15 5.5,15 Q9.5,15 9.5,10" />

    <!-- Stem — omit at ≤30dp for cleaner result -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M5.5,15 L5.5,17.5" />

</vector>