<?xml version="1.0" encoding="utf-8"?>
<!--
  Save icon — downward arrow into a tray (the modern "save/download" glyph).
  Reads clearly at small sizes (28–30dp in the Mini Recorder widget).
  Color applied via app:tint / imageTintList in the layout.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Downward arrow shaft -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M12,3 L12,15" />

    <!-- Arrowhead -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M7,10 L12,15 L17,10" />

    <!-- Tray / underline base -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M4,18 L4,20 L20,20 L20,18" />

</vector>