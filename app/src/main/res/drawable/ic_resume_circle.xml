<?xml version="1.0" encoding="utf-8"?>
<!--
  Resume circle — solid circle with a play triangle cut out of it.

  Uses a single <path> with fillType="evenOdd": the outer circle and the
  inner triangle are wound in opposite directions, so the triangle becomes
  transparent and the background shows through it.

  This means imageTintList tints the whole thing one color (e.g. yellow)
  and the triangle appears as a hole — giving crisp contrast at any tint
  without needing a second path.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M12,2 C6.477,2 2,6.477 2,12 C2,17.523 6.477,22 12,22 C17.523,22 22,17.523 22,12 C22,6.477 17.523,2 12,2 Z
            M9.5,16.5 L17.0,12.0 L9.5,7.5 Z
        " />

</vector>