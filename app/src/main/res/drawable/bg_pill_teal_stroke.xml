<?xml version="1.0" encoding="utf-8"?>
<!--
  Teal pill border — background for the selected-mark timestamp chip
  in the Record tab's extended mark controls panel.
  Matches the "selected" pill language used in the Listen tab's mark list.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <stroke
        android:width="1.5dp"
        android:color="@color/teal_a700" />
    <solid android:color="@android:color/transparent" />
    <corners android:radius="12dp" />
</shape>