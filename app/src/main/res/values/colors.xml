<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════
         TreeCast raw color palette.

         These are value-only definitions — no UI meaning is encoded
         in these names. All semantic roles are assigned in themes.xml
         via the custom attributes declared in attrs.xml.

         Nothing outside of themes.xml should reference these directly.
         ══════════════════════════════════════════════════════════════ -->

    <!-- Purple / brand -->
    <color name="purple_300">#9D96FF</color>
    <color name="purple_500">#6C63FF</color>
    <color name="purple_600">#4F48CC</color>

    <!-- Red / pink -->
    <color name="red_500">#FF3B3B</color>
    <color name="pink_700">#C2185B</color>
    <color name="pink_900">#880E4F</color>

    <!-- Teal -->
    <color name="teal_a700">#00BFA5</color>

    <!-- Greys (blue-tinted dark scale) -->
    <color name="grey_950">#0F0F14</color>
    <color name="grey_910">#111118</color>
    <color name="grey_900">#1A1A25</color>
    <color name="grey_800">#252535</color>

    <!-- Brown (warm dark) -->
    <color name="brown_950">#231A14</color>

    <!-- Yellows / ambers -->
    <color name="yellow_600">#F5C842</color>
    <color name="amber_800">#B8860B</color>

    <!-- Status greens / oranges -->
    <color name="green_500">#4CAF50</color>
    <color name="orange_600">#FFA726</color>

    <!-- Absolute -->
    <color name="white">#FFFFFFFF</color>
    <color name="black">#FF000000</color>
    <color name="transparent">#00000000</color>

</resources>