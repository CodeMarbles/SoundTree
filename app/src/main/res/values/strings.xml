<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════
         app_  —  Application-wide identity
         ══════════════════════════════════════════════════════════════ -->

    <!--
        app_name must stay exactly "app_name" — it is referenced by that
        exact key in AndroidManifest.xml (android:label="@string/app_name")
        and changing it requires a matching manifest edit.
    -->
    <string name="app_name">TreeCast</string>
    <string name="app_emoji">🪾</string>
    <!-- Format: "%1$s  %2$s" where %1$s = app_name, %2$s = app_emoji -->
    <string name="app_label_identity">%1$s  %2$s</string>

    <!-- Lock screen overlay -->
    <string name="app_label_locked">🔒  Screen Locked</string>


    <!-- ══════════════════════════════════════════════════════════════
         tab_  —  Bottom navigation labels
         (already well-named; kept as-is — changing them gains nothing)
         ══════════════════════════════════════════════════════════════ -->

    <string name="tab_settings">Settings</string>
    <string name="tab_record">Record</string>
    <string name="tab_workspace">Workspace</string>
    <string name="tab_library">Library</string>
    <string name="tab_listen">Listen</string>


    <!-- ══════════════════════════════════════════════════════════════
         common_  —  Shared UI that appears verbatim in 2+ screens.
         Be slow and deliberate about adding to this section.
         ══════════════════════════════════════════════════════════════ -->

    <string name="common_btn_save">Save</string>
    <string name="common_btn_cancel">Cancel</string>
    <string name="common_btn_delete">Delete</string>
    <string name="common_btn_rename">Rename</string>
    <string name="common_btn_move">Move</string>
    <string name="common_btn_unlock">Unlock</string>
    <string name="common_btn_ok">OK</string>

    <plurals name="common_label_recording_count">
        <item quantity="one">1 recording</item>
        <item quantity="other">%d recordings</item>
    </plurals>


    <!-- ══════════════════════════════════════════════════════════════
         topic_  —  Topic tree, topic picker, inbox tile
         ══════════════════════════════════════════════════════════════ -->

    <!--
        topic_label_unsorted is the plain display name used wherever a
        recording's topic is shown as text (e.g. media metadata, list rows).
        Change here to update everywhere.
    -->
    <string name="topic_label_unsorted">Unsorted</string>
    <!-- Emoji-prefixed variant used in picker rows and inbox tile -->
    <string name="topic_picker_label_unsorted">📥  Unsorted</string>

    <string name="topic_label_tile_topics">Topics</string>
    <string name="topic_label_tile_inbox">Inbox</string>

    <string name="topic_msg_empty_tree">No topics yet.\nTap + TOPIC to get started.</string>
    <string name="topic_msg_empty_inbox">Your unsorted recordings appear here.</string>

    <!-- Topic picker bottom sheet titles -->
    <string name="topic_picker_title_select">Select Topic</string>
    <string name="topic_picker_title_move">Move to…</string>
    <!-- The "top level" row label shown when reparenting a topic -->
    <string name="topic_picker_label_top_level">Top level</string>

    <!-- Inline topic tree item actions -->
    <string name="topic_btn_icon">Icon</string>
    <string name="topic_btn_details">Details</string>

    <!-- Topic tree context menu -->
    <string name="topic_action_new_subtopic">New Subtopic</string>

    <!-- Topic dialogs -->
    <string name="topic_dialog_rename_title">Rename Topic</string>
    <string name="topic_dialog_delete_title">Delete "%1$s"?</string>
    <string name="topic_dialog_delete_message">This topic will be permanently deleted.</string>


