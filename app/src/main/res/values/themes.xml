<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════
         TreeCast theme — light (default).

         res/values-night/themes.xml holds the dark overrides.
         AppCompatDelegate.setDefaultNightMode() in TreeCastApp selects
         between them based on the user's saved preference.
         ══════════════════════════════════════════════════════════════ -->

    <style name="Theme.TreeCast" parent="Theme.MaterialComponents.DayNight.NoActionBar">



        <!-- Material required slots -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_500</item>
        <item name="colorSecondaryVariant">@color/purple_600</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/grey_100</item>
        <item name="colorOnSurface">@color/navy_900</item>
        <item name="android:statusBarColor">@color/grey_50</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarColor">@color/grey_50</item>
        <item name="android:windowBackground">@color/grey_50</item>

        <!-- Brand -->
        <item name="colorAccent">@color/purple_500</item>
        <item name="colorAccentDark">@color/purple_600</item>

        <!-- Backgrounds & surfaces -->
        <item name="colorBackground">@color/grey_50</item>
        <item name="colorSurfaceBase">@color/grey_100</item>
        <item name="colorSurfaceElevated">@color/grey_200</item>
        <item name="colorMiniPlayerSurface">@color/slate_50</item>
        <item name="colorControlsTray">@color/cream_100</item>

        <!-- Buttons -->
        <item name="colorActionLockScreen">@color/amber_100</item>
        <item name="colorActionCancel">@color/red_700</item>
        <item name="colorActionSave">@color/green_800</item>
        <item name="colorError">@color/red_700</item>

        <!-- Text -->
        <item name="colorTextPrimary">@color/navy_900</item>
        <item name="colorTextSecondary">@color/slate_500</item>

        <!-- Bottom nav pill backgrounds — light -->
        <item name="colorNavBgSettings">@color/grey_200</item>
        <item name="colorNavBgRecord">@color/red_50</item>
        <item name="colorNavBgWorkspace">@color/green_100</item>
        <item name="colorNavBgLibrary">@color/brown_100</item>
        <item name="colorNavBgListen">@color/slate_50</item>

        <!-- Recording -->
        <item name="colorRecordActive">@color/red_500</item>
        <item name="colorRecordPause">@color/amber_500</item>
        <item name="colorRecordButtonBorder">@color/navy_900</item>
        <item name="colorDestructive">@color/red_500</item>
        <item name="colorMiniRecorderActive">@color/red_50</item>

        <!-- Mini Recorder -->
        <item name="colorMiniRecorderIdle">@color/red_40</item>
        <item name="colorMiniRecorderPaused">@color/yellow_50</item>

        <!-- Title bar pills -->
        <item name="colorPillPlayerFill">@color/blue_pill_100</item>
        <item name="colorPillPlayerStroke">#3358CC</item>
        <item name="colorPillRecorderPausedFill">@color/yellow_50</item>
        <item name="colorPillRecorderIdleStroke">#B07878</item>

        <!-- Marks -->
        <item name="colorMarkDefault">@color/pink_700</item>
        <item name="colorMarkSelected">@color/teal_a700</item>
        <item name="colorMarkAction">@color/pink_700</item>
        <item name="colorMarkSurface">@color/pink_50</item>

        <!-- Waveform -->
        <item name="colorWaveformUnplayed">@color/grey_200</item>
        <item name="colorWaveformGradientStart">@color/purple_600</item>
        <item name="colorWaveformGradientMid">@color/purple_500</item>
        <item name="colorWaveformGradientEnd">@color/purple_300</item>
        <item name="colorWaveformFade">@color/grey_50</item>
        <item name="colorPlayhead">@color/navy_900</item>

        <!-- Status & labels -->
        <item name="colorStatusSuccess">@color/green_500</item>
        <item name="colorStatusWarning">@color/orange_600</item>
        <item name="colorStatusLockScreen">@color/yellow_600</item>
        <item name="colorStatusRecordingLabel">@color/amber_800</item>

    </style>

    <style name="Theme.TreeCast.Splash" parent="Theme.TreeCast">
        <item name="android:windowBackground">@color/grey_50</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="Theme.TreeCast.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorSurface">@color/grey_100</item>
        <item name="colorOnSurface">@color/navy_900</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="bottomSheetStyle">@style/Widget.TreeCast.BottomSheet</item>
    </style>

    <style name="Widget.TreeCast.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/grey_100</item>
    </style>

    <style name="Animation.TreeCast.SlideUpDown" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/slide_in_up</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>

    <style name="Theme.TreeCast.FullscreenDialog" parent="Theme.TreeCast">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">?attr/colorBackground</item>
        <item name="android:windowAnimationStyle">@style/Animation.TreeCast.SlideUpDown</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>