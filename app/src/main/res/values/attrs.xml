<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════
         SoundTree custom theme attributes.

         All UI color references in layouts, drawables, and Kotlin code
         should point to these attributes (via ?attr/...) rather than
         to @color/ resources directly. The theme resolves each attribute
         to the appropriate raw color for the current mode (dark/light).
         ══════════════════════════════════════════════════════════════ -->

    <!-- Brand -->
    <attr name="colorAccent"            format="color" />
    <attr name="colorAccentDark"        format="color" />

    <!-- Backgrounds & surfaces -->
    <attr name="colorBackground"        format="color" />
    <attr name="colorSurfaceBase"       format="color" />
    <attr name="colorSurfaceElevated"   format="color" />
    <attr name="colorControlsTray"      format="color" />

    <!-- Text -->
    <attr name="colorTextPrimary"       format="color" />
    <attr name="colorTextSecondary"     format="color" />

    <!-- Bottom nav per-tab pill backgrounds -->
    <attr name="colorNavBgSettings" format="color" />
    <attr name="colorNavBgRecord"   format="color" />
    <attr name="colorNavBgLibrary"  format="color" />
    <attr name="colorNavBgListen"   format="color" />
    <attr name="colorNavBgWorkspace" format="color" />

    <!-- Recording -->
    <attr name="colorRecordActive"      format="color" />
    <attr name="colorRecordPause"       format="color" />
    <attr name="colorRecordButtonBorder" format="color" />
    <attr name="colorDestructive"       format="color" />

    <!-- Mini Player distinct surface -->
    <attr name="colorMiniPlayerSurface" format="color" />

    <!-- Mini Recorder -->
    <attr name="colorMiniRecorderIdle"   format="color" />
    <attr name="colorMiniRecorderActive" format="color" />
    <attr name="colorMiniRecorderPaused" format="color" />

    <!-- Title bar pills -->
    <attr name="colorPillPlayerFill"          format="color" />
    <attr name="colorPillPlayerStroke"        format="color" />
    <attr name="colorPillRecorderPausedFill"  format="color" />
    <attr name="colorPillRecorderIdleStroke"  format="color" />

    <!-- Buttons -->
    <attr name="colorActionCancel" format="color" />
    <attr name="colorActionSave"   format="color" />
    <attr name="colorActionLockScreen" format="color" />

    <!-- Marks -->
    <attr name="colorMarkDefault"       format="color" />
    <attr name="colorMarkSelected"      format="color" />
    <attr name="colorMarkAction"        format="color" />
    <attr name="colorMarkSurface"       format="color" />

    <!-- Waveform -->
    <attr name="colorWaveformUnplayed"      format="color" />
    <attr name="colorWaveformGradientStart" format="color" />
    <attr name="colorWaveformGradientMid"   format="color" />
    <attr name="colorWaveformGradientEnd"   format="color" />
    <attr name="colorWaveformFade"          format="color" />
    <attr name="colorPlayhead"              format="color" />

    <!-- Status & labels -->
    <attr name="colorError"                 format="color" />
    <attr name="colorStatusSuccess"         format="color" />
    <attr name="colorStatusWarning"         format="color" />
    <attr name="colorStatusLockScreen"      format="color" />
    <attr name="colorStatusRecordingLabel"  format="color" />

    <!-- Semantic status surface + foreground pairs.
             Used by the backup strip and any future status-tinted surface. -->
    <attr name="colorStatusRunningBackground"  format="color" />
    <attr name="colorStatusRunningForeground"  format="color" />
    <attr name="colorStatusSuccessBackground"  format="color" />
    <attr name="colorStatusSuccessForeground"  format="color" />
    <attr name="colorStatusWarningBackground"  format="color" />
    <attr name="colorStatusWarningForeground"  format="color" />
    <attr name="colorStatusFailedBackground"   format="color" />
    <attr name="colorStatusFailedForeground"   format="color" />

</resources>